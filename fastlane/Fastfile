default_platform(:ios)

platform :ios do
  desc "Take screenshots for App Store using Snapshot"
  lane :snapshot do
    snapshot(
      scheme: "CountyTracker",
      output_directory: "~/Downloads/CountyTrackerScreenshots",
      clean: true
    )
  end

  desc "Organize, resize, and upload screenshots to App Store Connect"
  lane :upload_screenshots do
    sh("bash fastlane/organize_screenshots.sh")
    sh("bash fastlane/resize_screenshots.sh")
    deliver(
      screenshots_path: "fastlane/metadata",
      skip_binary_upload: true,
      submit_for_review: false
    )
  end
end
