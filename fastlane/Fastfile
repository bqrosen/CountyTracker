default_platform(:ios)

platform :ios do
  desc "Take screenshots for App Store using Snapshot"
  lane :snapshot do
    snapshot(
      scheme: "CountyTracker",
      output_directory: "~/Downloads/CountyTrackerScreenshots",
      clean: true
    )
  end

  desc "Organize, resize, and upload screenshots to App Store Connect"
  lane :upload_screenshots do
    sh("bash fastlane/organize_screenshots.sh")
    sh("bash fastlane/resize_screenshots.sh")
    # Prefer API key provided via environment variables (recommended for CI).
    # Supported env vars:
    # - APP_STORE_CONNECT_KEY_ID
    # - APP_STORE_CONNECT_ISSUER_ID
    # - APP_STORE_CONNECT_PRIVATE_KEY  (the contents of the .p8 file)
    api_key = nil
    if ENV["APP_STORE_CONNECT_KEY_ID"] && ENV["APP_STORE_CONNECT_ISSUER_ID"] && ENV["APP_STORE_CONNECT_PRIVATE_KEY"]
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
        key: ENV["APP_STORE_CONNECT_PRIVATE_KEY"]
      )
    elsif File.exist?("fastlane/AppStoreConnectAPIKey.json")
      api_key = app_store_connect_api_key(path: "fastlane/AppStoreConnectAPIKey.json")
    end

    if api_key
      deliver(
        api_key: api_key,
        screenshots_path: "fastlane/metadata",
        skip_binary_upload: true,
        submit_for_review: false
      )
    else
      deliver(
        screenshots_path: "fastlane/metadata",
        skip_binary_upload: true,
        submit_for_review: false
      )
    end
  end
end
